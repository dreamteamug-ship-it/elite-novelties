{
  "version": 2,
  "functions": {
    "app/api/webhooks/**/*": {
      "maxDuration": 60
    },
    "app/api/fulfillment/**/*": {
      "maxDuration": 60
    },
    "app/api/checkout/verify-usdt/**/*": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, stripe-signature, Authorization"
        }
      ]
    }
  ]
}